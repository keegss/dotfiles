##
# Vim
##

# Swap
[._]*.s[a-v][a-z]
!*.svg  # comment out if you don't need vector files
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Session
Session.vim
Sessionx.vim

# Temporary
.netrwhist
*~
# Auto-generated tag files
tags
# Persistent undo
[._]*.un~

## 
# VSCode
##

.vscode/*
!.vscode/keybindings.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets

# Local History for Visual Studio Code
.history/

# Built Visual Studio Code Extensions
*.vsix

##
# Claude Code
##

# settings.json is generated by dotfiles-magic (cc-setup + claude_config_sync).
# Only settings.overrides.json should be checked in.
.claude/settings.json
.claude/.claude
.claude/ide/